#!/usr/bin/env bash
# govern repo pre-commit hook.
#
# Runs all four generators unconditionally and stages their outputs so the
# committed tree always has up-to-date generated artifacts.
#
# Generators run in a fixed order:
#   1. gen-configure-mcp.sh    — runtime-MCP-tool allow blocks in
#                                framework/bootstrap/configure/{claude,auggie}.md
#                                (runs before gen-claude-commands.sh so the
#                                 regenerated configure.md picks up changes)
#   2. gen-claude-commands.sh  — .claude/commands/gov/*.md from framework/commands/
#   3. gen-spec-deps.sh        — frontmatter dependencies from body inline links
#                                (runs before gen-readme-table.sh so the README
#                                 table reflects post-derivation deps)
#   4. gen-readme-table.sh     — Feature Specs table in README.md
#   5. gen-help-tables.sh      — five command tables in framework/commands/help.md
#
# When staged files include anything under runtime/, this hook additionally
# runs `cargo fmt --check`, `cargo clippy --all-targets --all-features
# -- -D warnings`, and `cargo test` against the runtime crate. Skip the
# cargo checks for a single commit with GOVERN_SKIP_RUNTIME_CHECKS=1.
#
# Installation: scripts/install-hooks.sh sets `git config core.hooksPath .githooks`.

set -euo pipefail
shopt -s nullglob
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

scripts/gen-configure-mcp.sh
scripts/gen-claude-commands.sh > /dev/null
scripts/gen-spec-deps.sh
scripts/gen-readme-table.sh
scripts/gen-help-tables.sh

# Stage any generator-produced changes to their known output paths.
git add framework/bootstrap/configure/claude.md framework/bootstrap/configure/auggie.md
git add .claude/commands/gov/ 2>/dev/null || true
git add README.md
git add framework/commands/help.md
for f in specs/[0-9][0-9][0-9]-*/spec.md specs/[0-9][0-9][0-9]-*/spec-and-plan.md; do
  git add "$f"
done

# Runtime crate verification — only when staged changes touch runtime/.
if [[ "${GOVERN_SKIP_RUNTIME_CHECKS:-0}" != "1" ]] \
   && git diff --cached --name-only | grep -q '^runtime/'; then
  if ! command -v cargo > /dev/null; then
    echo "pre-commit: runtime/ changes staged but cargo not on PATH; skipping verification" >&2
  else
    (
      cd runtime
      cargo fmt --all -- --check
      cargo clippy --all-targets --all-features -- -D warnings
      cargo test --quiet
    )
  fi
fi
